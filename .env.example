# Environment variables untuk deployment
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://username:password@hostname:5432/tesla_stock

# Alternatif: Pisahkan konfigurasi
DB_HOST=your-database-host.com
DB_PORT=5432
DB_NAME=tesla_stock
DB_USER=your_username
DB_PASSWORD=your_password

# Flask Configuration
FLASK_ENV=production
DEBUG=false

# Optional: Add your own configuration
# API_KEY=your_api_key
# SECRET_KEY=your_secret_key
