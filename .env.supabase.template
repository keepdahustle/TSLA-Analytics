# ============================================================================
# SUPABASE POSTGRESQL CONNECTION TEMPLATE
# 
# Instruksi:
# 1. Get DATABASE_URL dari Supabase Dashboard:
#    Project Settings → Database → Connection String (Pooling URL)
# 2. Replace [DATABASE_URL] di bawah dengan URL Anda
# 3. Rename file ini ke .env
# 4. Jangan commit .env ke git!
# ============================================================================

# PostgreSQL Connection String dari Supabase
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# 
# PENTING: Gunakan Connection Pooling URL (port 6543) untuk Vercel/serverless!
# Pooling URL format:
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooling.supabase.com:6543/postgres
#
# Contoh:
# DATABASE_URL=postgresql://postgres.abcdefg123:your_password@aws-0-ap-southeast-1.pooling.supabase.com:6543/postgres
#
# Atau gunakan direct URL (port 5432):
# DATABASE_URL=postgresql://postgres:your_password@tsla-analytics.supabase.co:5432/postgres

DATABASE_URL=

# Alternatif: Parse individual connection parameters
# (Gunakan ini jika DATABASE_URL tidak works)
# DB_HOST=aws-0-[region].pooling.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your_password

# Flask Configuration
FLASK_ENV=production

# Debug Mode (set ke false di production)
DEBUG=false

# ============================================================================
# STEP-BY-STEP CARA MENDAPATKAN DATABASE_URL:
# ============================================================================
#
# 1. Buka https://supabase.com/dashboard
# 2. Pilih project: "tsla-analytics"
# 3. Sidebar → "Project Settings"
# 4. Tab → "Database"
# 5. Cari section "Connection string"
# 6. Pilih "URI" tab
# 7. Copy seluruh connection string
# 8. Paste ke DATABASE_URL di atas
#
# VERSI POOLING (Recommended untuk Vercel):
# Ganti connection string ini:
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooling.supabase.com:6543/postgres
#
# Contoh lengkap:
# DATABASE_URL=postgresql://postgres.xyzabcdef123:MySecurePassword123@aws-0-ap-southeast-1.pooling.supabase.com:6543/postgres
#
# ============================================================================

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# 
# ⚠️  SECURITY:
#     - Jangan commit .env ke git (sudah di .gitignore)
#     - Jangan share DATABASE_URL dengan siapa pun
#     - Rotate password secara berkala di Supabase
#
# 📌 CONNECTION POOLING:
#     - Vercel serverless HARUS gunakan pooling (port 6543)
#     - Local development bisa gunakan direct (port 5432)
#     - Pooling lebih efisien untuk high concurrency
#
# 🔄 TESTING:
#     - Run: python setup.py
#     - Jika berhasil, akan load data dari CSV ke Supabase
#
# 📡 VERCEL DEPLOYMENT:
#     - Add DATABASE_URL ke Vercel Project Settings → Environment Variables
#     - Deploy akan otomatis menggunakan env variable ini
#     - Run: vercel --prod
#
# ============================================================================
